{
  "title": "Redis Dashboard",
  "uid": "redis-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Redis Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "redis_up{job=\"redis\"}",
          "legendFormat": "Status",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Used",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 40000000 }, { "color": "red", "value": 48000000 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory Usage %",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "100 * redis_memory_used_bytes{job=\"redis\"} / redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Usage %",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "redis_connected_clients{job=\"redis\"}",
          "legendFormat": "Clients",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 5,
      "title": "Total Keys",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(redis_db_keys{job=\"redis\"})",
          "legendFormat": "Keys",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": 0 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 6,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds{job=\"redis\"}",
          "legendFormat": "Uptime",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 7,
      "title": "Cache Hit Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[1m])",
          "legendFormat": "Hits/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "rate(redis_keyspace_misses_total{job=\"redis\"}[1m])",
          "legendFormat": "Misses/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Hits/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Misses/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 8,
      "title": "Commands Processed / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{job=\"redis\"}[1m])",
          "legendFormat": "Commands/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 }, "color": { "fixedColor": "blue", "mode": "fixed" } }
      }
    },
    {
      "id": 9,
      "title": "Memory Used Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{job=\"redis\"}",
          "legendFormat": "Used",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis\"}",
          "legendFormat": "Max (50MB)",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Max (50MB)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }, { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }] }
        ]
      }
    },
    {
      "id": 10,
      "title": "Expired Keys / sec",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(redis_expired_keys_total{job=\"redis\"}[1m])",
          "legendFormat": "Expired/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 }, "color": { "fixedColor": "orange", "mode": "fixed" } }
      }
    }
  ]
}
